# Copy this file to `.env` in this directory or in the package root.

# Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=

# Optional model overrides
OPENAI_TEXT_MODEL=gpt-4o-mini
ANTHROPIC_TEXT_MODEL=claude-sonnet-4-6
GEMINI_TEXT_MODEL=gemini-2.5-flash
DEEPSEEK_TEXT_MODEL=deepseek-chat
XAI_TEXT_MODEL=grok-3-mini

# Optional OpenAI-compatible custom provider
CUSTOM_PROVIDER_NAME=openrouter
CUSTOM_PROVIDER_API_KEY=
CUSTOM_PROVIDER_BASE_URL=https://openrouter.ai/api/v1
CUSTOM_PROVIDER_MODEL=openai/gpt-4o-mini

# Tracking
CONTENT_TRACKING_PATH=examples/var/tracking
